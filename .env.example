# GitHub Statistics API Configuration

# URL for the hosted GitHub stats backend
NEXT_PUBLIC_BACKEND_URL=https://your-backend-url/api/github
# URL for local development of the GitHub stats backend
NEXT_PUBLIC_LOCAL_BACKEND_URL=http://localhost:8000/api/github

# Contact Form Configuration (Formspree)
# Get your form ID from https://formspree.io/
NEXT_PUBLIC_FORMSPREE_FORM_ID=your-formspree-form-id

# Security Configuration (Cloudflare Turnstile)
# Get your site key from https://dash.cloudflare.com/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Personal Information
# Email address displayed in the contact section
NEXT_PUBLIC_EMAIL=your@email.com
# UPI ID for the support/donation section
NEXT_PUBLIC_UPI_ID=your_name@upi
