# =============================================================================
# DEPLOYMENT TARGET
# =============================================================================

# Set to "true" when building for GitHub Pages (static export).
# Enables: output: 'export', images.unoptimized, disables server-only hooks.
# Leave unset (or "false") for Node / Vercel / Railway deployments.
# Usage in GitHub Actions:
#   env:
#     GITHUB_PAGES: true
GITHUB_PAGES=true


# =============================================================================
# GITHUB STATISTICS BACKEND
# =============================================================================

# Base URL for the hosted GitHub stats backend (or local dev server).
# This should point to your self-hosted / third-party stats API.
# Local dev example  : http://localhost:3001/api/github
# Hosted example     : https://your-backend-url/api/github
NEXT_PUBLIC_BACKEND_URL=https://your-backend-url/api/github


# =============================================================================
# CONTACT FORM  (Formspree)
# =============================================================================

# Your Formspree form ID — found in the form dashboard after creation.
# Sign up / create a form at: https://formspree.io/
# The ID is the last segment of your endpoint, e.g.:
#   https://formspree.io/f/abcd1234  →  NEXT_PUBLIC_FORMSPREE_FORM_ID=abcd1234
NEXT_PUBLIC_FORMSPREE_FORM_ID=your-formspree-form-id


# =============================================================================
# SECURITY  (Cloudflare Turnstile)
# =============================================================================

# Turnstile site key for the CAPTCHA widget on the contact form.
# ⚠️  This is the PUBLIC site key — safe to expose in the browser.
#     Never put your SECRET key here.
# Generate one at: https://dash.cloudflare.com/ → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key


# =============================================================================
# PERSONAL INFORMATION
# =============================================================================

# Email address displayed publicly in the contact section.
NEXT_PUBLIC_EMAIL=your@email.com

# UPI ID shown in the support / donation section.
# Format: name@bankhandle  (e.g. yourname@upi, yourname@okicici)
NEXT_PUBLIC_UPI_ID=your_name@upi

# Buy Me a Coffee username — used to generate your donation page link.
# Your profile URL will be: https://buymeacoffee.com/<username>
NEXT_PUBLIC_BUYMEACOFFEE_USERNAME=your-username

# =============================================================================
# SEO & VERIFICATION
# =============================================================================

# Google Search Console site verification token.
# Found in Search Console → Settings → Ownership verification → HTML tag method.
# Copy only the content="..." value, not the full meta tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-site-verification-token